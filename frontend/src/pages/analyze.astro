---
/**
 * Página de análisis — consume el stream SSE del backend y muestra el progreso
 * de los 7 agentes y el documento generado en tiempo real.
 *
 * Rutas que llegan aquí:
 * - /analyze?url=https://github.com/usuario/repo  (desde el formulario de la home)
 * - /usuario/repo  (truco de URL, nginx hace el rewrite a esta ruta)
 */
import Layout from "../layouts/Layout.astro";

const AGENTS = [
  { id: "hopper",    label: "Grace Hopper",      sublabel: "Stack tecnológico",   wiki: "https://es.wikipedia.org/wiki/Grace_Hopper" },
  { id: "kay",       label: "Alan Kay",           sublabel: "Arquitectura",        wiki: "https://es.wikipedia.org/wiki/Alan_Kay" },
  { id: "liskov",    label: "Barbara Liskov",     sublabel: "Base de datos",       wiki: "https://es.wikipedia.org/wiki/Barbara_Liskov" },
  { id: "fielding",  label: "Roy Fielding",       sublabel: "API y contratos",     wiki: "https://es.wikipedia.org/wiki/Roy_Fielding" },
  { id: "lamarr",    label: "Hedy Lamarr",        sublabel: "Frontend",            wiki: "https://es.wikipedia.org/wiki/Hedy_Lamarr" },
  { id: "knuth",     label: "Donald Knuth",       sublabel: "Lógica de negocio",   wiki: "https://es.wikipedia.org/wiki/Donald_Knuth" },
  { id: "conway",    label: "Lynn Conway",        sublabel: "DevOps y despliegue", wiki: "https://es.wikipedia.org/wiki/Lynn_Conway" },
  { id: "hamilton",  label: "Margaret Hamilton",  sublabel: "Integración",         wiki: "https://es.wikipedia.org/wiki/Margaret_Hamilton_(cient%C3%ADfica)" },
];
---

<Layout
  title="Analizar repositorio"
  description="Lanza un análisis técnico de cualquier repositorio público de GitHub y sigue el progreso de los agentes en tiempo real."
  keywords="analizar repositorio github, análisis técnico repo, agentes ia código, reconstruir repositorio"
  noindex={true}
>
  <!-- Popup modal: solicita email antes de iniciar el análisis -->
  <div id="popup-overlay" class="popup-overlay">
    <div
      id="popup-dialog"
      class="popup-card"
      role="dialog"
      aria-modal="true"
      aria-labelledby="popup-title"
      aria-describedby="popup-subtitle"
    >
      <div class="popup-header">
        <span class="popup-tag">Análisis de repositorio</span>
        <h2 id="popup-title" class="popup-title">Antes de empezar</h2>
        <p id="popup-subtitle" class="popup-subtitle">
          El análisis suele tardar entre 3 y 10 minutos, según el tamaño del repositorio.
        </p>
      </div>

      <div class="popup-body">
        <!-- Campo de email -->
        <div class="field-group">
          <label for="popup-email" id="email-label" class="field-label">
            Email para recibir el resultado
          </label>
          <input
            type="email"
            id="popup-email"
            class="field-input"
            placeholder="tu@email.com"
            autocomplete="email"
          />
          <span id="email-help" class="field-help">
            Opcional: te avisamos cuando termine el análisis.
          </span>
        </div>

        <!-- Toggle de privacidad -->
        <div class="toggle-row">
          <div class="toggle-info">
            <span id="privacy-label" class="toggle-label">Acepto la <a href="/legal" target="_blank" rel="noopener" class="toggle-link">política de privacidad</a></span>
            <span id="toggle-sub" class="toggle-sub">Tu email solo se usa para enviarte el resultado.</span>
          </div>
          <button
            id="privacy-toggle"
            class="toggle-btn"
            role="switch"
            aria-checked="false"
            aria-labelledby="privacy-label toggle-sub"
            type="button"
          >
            <span class="toggle-thumb"></span>
          </button>
        </div>

        <div class="toggle-row toggle-row-secondary">
          <div class="toggle-info">
            <span id="updates-label" class="toggle-label">Quiero avisos si aparece un análisis nuevo de este repo</span>
            <span id="updates-sub" class="toggle-sub">Solo te escribiremos cuando cambie el SHA. Podrás darte de baja desde cualquier correo.</span>
          </div>
          <button
            id="updates-toggle"
            class="toggle-btn"
            role="switch"
            aria-checked="false"
            aria-labelledby="updates-label updates-sub"
            type="button"
          >
            <span class="toggle-thumb"></span>
          </button>
        </div>

        <!-- Caja informativa dinámica -->
        <div id="info-box" class="info-box info-amber" aria-live="polite">
          <span class="info-icon">!</span>
          <p class="info-text" id="info-text">
            Cuando el análisis arranque podrás cerrar esta pestaña.
            Si dejas tu email, te avisaremos cuando termine.
          </p>
        </div>

        <div id="measure-box" class="measure-box measure-hidden" aria-live="polite">
          <div class="measure-header">
            <div>
              <p id="measure-title" class="measure-title">Midiendo el repositorio...</p>
              <p id="measure-message" class="measure-message">
                Gracias por esperar. Estamos calculando el tamaño útil del repo para estimar el análisis más fiable.
              </p>
            </div>
            <p id="measure-stats" class="measure-stats">
              Repos pequeños: 1-3s · medianos: 3-8s · grandes: 8-15s
            </p>
          </div>
          <div class="measure-track" aria-hidden="true">
            <span class="measure-fill"></span>
          </div>
          <div class="measure-blocks" aria-hidden="true">
            <span class="measure-block"></span>
            <span class="measure-block"></span>
            <span class="measure-block"></span>
          </div>
          <div id="measure-limit-panel" class="measure-limit-panel measure-limit-panel-hidden" aria-hidden="true">
            <div class="measure-pill measure-pill-alert">
              <span class="measure-pill-label">Archivos detectados</span>
              <strong id="measure-detected-count" class="measure-pill-value">0</strong>
            </div>
            <div class="measure-pill">
              <span class="measure-pill-label">Plan gratuito</span>
              <strong id="measure-limit-count" class="measure-pill-value">2500</strong>
            </div>
          </div>
          <p id="measure-limit-note" class="measure-limit-note measure-limit-note-hidden"></p>
        </div>
      </div>

      <div class="popup-footer">
        <button id="popup-cancel" class="btn-secondary" type="button">Cancelar</button>
        <button id="popup-start" class="btn-primary" type="button">
          Iniciar análisis
        </button>
      </div>
    </div>
  </div>

  <!-- Barra de URL del repo analizado -->
  <div class="url-bar">
    <input
      type="text"
      id="url-display"
      class="url-input"
      readonly
      value="Cargando..."
    />
    <a href="/" class="btn-analyze">Analizar</a>
  </div>

  <!-- Banner de caché (oculto hasta que se muestre un resultado cacheado) -->
  <div id="cache-banner" class="cache-banner cache-banner-hidden">
    <span id="cache-banner-text"></span>
    <button id="force-new-btn" class="btn-force-new" type="button">Análisis nuevo</button>
  </div>

  <div id="delivery-banner" class="delivery-banner delivery-banner-hidden">
    <span id="delivery-banner-text"></span>
  </div>

  <!-- Layout principal: sidebar + área de documento -->
  <div class="analysis-layout">
    <!-- Sidebar: Agentes -->
    <aside>
      <div class="sidebar-header">Agentes</div>
      {
        AGENTS.map((agent) => (
          <div class="agent-row" id={`agent-${agent.id}`}>
            <span class="agent-check" id={`check-${agent.id}`}>&nbsp;</span>
            <div class="agent-info">
              <span class="agent-label">
                  {agent.label}
                  <a href={agent.wiki} target="_blank" rel="noopener" class="wiki-link" title={`Wikipedia: ${agent.label}`}>i</a>
                </span>
              <span class="agent-sub">{agent.sublabel}</span>
            </div>
            <span class="agent-status" id={`status-${agent.id}`}>pendiente</span>
          </div>
        ))
      }
    </aside>

    <!-- Área del documento -->
    <main>
      <!-- Encabezado del documento -->
      <div class="doc-header">
        <div class="doc-title-area">
          <h2 id="doc-title">Análisis en curso...</h2>
          <p id="doc-meta" class="doc-meta"></p>
        </div>
        <div class="doc-actions">
          <button id="copy-btn" disabled class="btn-action">Copiar</button>
          <button id="download-btn" disabled class="btn-action btn-action-primary">Descargar .md</button>
        </div>
      </div>

      <!-- Cuerpo del documento -->
      <div id="doc-body" class="doc-body">
        <p class="doc-waiting">Cargando...</p>
      </div>
    </main>
  </div>

</Layout>

<script>
  import {
    getAnalysisTicket,
    getBackendCapabilities,
    measureRepositoryContext,
    startAnalysis,
  } from "../scripts/stream-client";
  import type {
    CachedAnalysisData,
    RepoPreflightData,
  } from "../scripts/stream-client";

  const ANALYZE_BACKEND_URL =
    (import.meta as unknown as { env: Record<string, string> }).env
      ?.PUBLIC_BACKEND_URL ?? "http://localhost:8410";

  // Determinar la URL del repo desde query param o path
  const searchParams = new URLSearchParams(window.location.search);
  const queryUrl = searchParams.get("url");
  const repoUrl = queryUrl ?? null;
  const forceNewRequested =
    searchParams.get("force") === "true" || searchParams.get("force") === "1";

  if (!repoUrl) {
    window.location.href = "/";
  }

  // Mostrar la URL en la barra
  const urlDisplay = document.getElementById("url-display") as HTMLInputElement;
  urlDisplay.value = repoUrl?.replace("https://", "") ?? "";

  const btnAnalyze = document.querySelector(".btn-analyze") as HTMLAnchorElement;
  btnAnalyze.href = `/?url=${encodeURIComponent(repoUrl ?? "")}`;

  // ── Popup lógica ─────────────────────────────────────────────────────────
  const overlay      = document.getElementById("popup-overlay")!;
  const popupDialog  = document.getElementById("popup-dialog")!;
  const emailInput   = document.getElementById("popup-email") as HTMLInputElement;
  const emailLabel   = document.getElementById("email-label")!;
  const emailHelp    = document.getElementById("email-help")!;
  const toggleBtn    = document.getElementById("privacy-toggle") as HTMLButtonElement;
  const toggleSub    = document.getElementById("toggle-sub")!;
  const updatesToggleBtn = document.getElementById("updates-toggle") as HTMLButtonElement;
  const updatesSub = document.getElementById("updates-sub")!;
  const infoBox      = document.getElementById("info-box")!;
  const infoText     = document.getElementById("info-text")!;
  const measureBox   = document.getElementById("measure-box")!;
  const measureTitle = document.getElementById("measure-title")!;
  const measureMessage = document.getElementById("measure-message")!;
  const measureStats = document.getElementById("measure-stats")!;
  const measureLimitPanel = document.getElementById("measure-limit-panel")!;
  const measureDetectedCount = document.getElementById("measure-detected-count")!;
  const measureLimitCount = document.getElementById("measure-limit-count")!;
  const measureLimitNote = document.getElementById("measure-limit-note")!;
  const cancelBtn    = document.getElementById("popup-cancel")!;
  const startBtn     = document.getElementById("popup-start")!;
  const deliveryBanner = document.getElementById("delivery-banner")!;
  const deliveryBannerText = document.getElementById("delivery-banner-text")!;
  let markdownRendererPromise:
    | Promise<typeof import("../scripts/render-markdown")>
    | null = null;

  function getMarkdownRenderer() {
    markdownRendererPromise ??= import("../scripts/render-markdown");
    return markdownRendererPromise;
  }

  let privacyAccepted = false;
  let futureUpdatesOptIn = false;
  let collectedEmail  = "";
  let capabilitiesReady = false;
  let emailNotificationsEnabled = false;
  let analysisPendingOrRunning = false;
  let canLeaveWithoutRisk = true;

  function hideMeasureBox() {
    measureBox.classList.add("measure-hidden");
    measureBox.dataset.mode = "";
    hideMeasureLimitPanel();
  }

  function hideMeasureLimitPanel() {
    measureLimitPanel.classList.add("measure-limit-panel-hidden");
    measureLimitPanel.setAttribute("aria-hidden", "true");
    measureLimitNote.classList.add("measure-limit-note-hidden");
    measureLimitNote.textContent = "";
  }

  function showMeasureLimitPanel(preflight: RepoPreflightData) {
    measureDetectedCount.textContent = String(preflight.candidate_files);
    measureLimitCount.textContent = String(preflight.candidate_file_limit);
    measureLimitNote.textContent =
      `En la versión gratuita analizamos hasta ${preflight.candidate_file_limit} archivos útiles por repositorio para mantener la calidad y el coste de contexto bajo control.`;
    measureLimitPanel.classList.remove("measure-limit-panel-hidden");
    measureLimitPanel.setAttribute("aria-hidden", "false");
    measureLimitNote.classList.remove("measure-limit-note-hidden");
  }

  function showMeasuringState() {
    measureBox.className = "measure-box measure-measuring";
    measureBox.dataset.mode = "measuring";
    hideMeasureLimitPanel();
    measureTitle.textContent = "Midiendo el repositorio...";
    measureMessage.textContent =
      "Gracias por esperar. Estamos calculando el tamaño útil del repo para estimar el análisis más fiable.";
    measureStats.textContent =
      "Repos pequeños: 1-3s · medianos: 3-8s · grandes: 8-15s";
  }

  function formatCompactNumber(value: number) {
    return new Intl.NumberFormat("es-ES", { notation: "compact" }).format(value);
  }

  function getMeasuredCandidateCount(preflight: RepoPreflightData) {
    return preflight.measured_candidate_files ?? preflight.candidate_files;
  }

  function getMeasureStats(preflight: RepoPreflightData) {
    if (preflight.reason === "file_count_limit") {
      const measuredCount = getMeasuredCandidateCount(preflight);
      return preflight.measurement_limited
        ? `${preflight.candidate_files} archivos analizables detectados · ${measuredCount} medidos en detalle · límite gratuito: ${preflight.candidate_file_limit}`
        : `${preflight.candidate_files} archivos analizables detectados · límite gratuito: ${preflight.candidate_file_limit}`;
    }

    if (preflight.reason === "repo_size_limit") {
      const repoSizeMb = preflight.repo_size_kb
        ? Math.max(1, Math.round(preflight.repo_size_kb / 1024))
        : null;
      const limitMb = preflight.repo_size_limit_mb ?? 100;
      return repoSizeMb
        ? `~${repoSizeMb} MB detectados · límite ${limitMb} MB`
        : `tamaño bruto fuera de rango · límite ${limitMb} MB`;
    }

    if (preflight.measurement_limited) {
      const measuredCount = getMeasuredCandidateCount(preflight);
      return `${preflight.selected_files}/${measuredCount} archivos clave priorizados · ${formatCompactNumber(preflight.selected_chars)} chars útiles · ${preflight.candidate_files} detectados`;
    }

    return `${preflight.selected_files}/${preflight.candidate_files} archivos clave · ${formatCompactNumber(preflight.selected_chars)} chars útiles`;
  }

  function getTooLargeMessage(preflight: RepoPreflightData) {
    if (preflight.reason === "file_count_limit") {
      const measuredCount = getMeasuredCandidateCount(preflight);
      return preflight.measurement_limited
        ? `Hemos detectado ${preflight.candidate_files} archivos analizables y hemos medido en detalle los ${measuredCount} más informativos. Aun así, este repo supera el límite gratuito actual de ${preflight.candidate_file_limit} archivos útiles por repositorio.`
        : `Hemos detectado ${preflight.candidate_files} archivos analizables. En esta versión gratuita analizamos hasta ${preflight.candidate_file_limit} archivos útiles por repositorio para mantener el coste de contexto bajo control.`;
    }

    if (preflight.reason === "repo_size_limit") {
      const repoSizeMb = preflight.repo_size_kb
        ? Math.max(1, Math.round(preflight.repo_size_kb / 1024))
        : null;
      const limitMb = preflight.repo_size_limit_mb ?? 100;
      return repoSizeMb
        ? `El repositorio ocupa aproximadamente ${repoSizeMb} MB, por encima del límite actual de ${limitMb} MB para una sola pasada fiable.`
        : `El repositorio supera el límite actual de tamaño bruto permitido para una sola pasada fiable.`;
    }

    return "Este repositorio supera el tamaño recomendado para un análisis fiable en una sola pasada. Te recomendamos probar con un repo más pequeño o dividir el análisis.";
  }

  function getTooLargeTitle(preflight: RepoPreflightData) {
    return preflight.reason === "file_count_limit"
      ? "Límite gratuito superado."
      : "Repositorio demasiado grande para una sola pasada.";
  }

  function showMeasuredState(preflight: RepoPreflightData) {
    measureBox.className = `measure-box measure-${preflight.mode}`;
    measureBox.dataset.mode = preflight.mode;
    measureStats.textContent = getMeasureStats(preflight);
    hideMeasureLimitPanel();

    if (preflight.mode === "normal") {
      measureTitle.textContent = "Repositorio apto para análisis completo.";
      measureMessage.textContent =
        "El contexto útil entra dentro del presupuesto previsto. Arrancamos el análisis completo.";
      return;
    }

    if (preflight.mode === "optimized") {
      measureTitle.textContent = "Repositorio amplio detectado.";
      measureMessage.textContent = preflight.measurement_limited
        ? "Hemos detectado más archivos útiles de los que medimos en detalle. Priorizaremos los más informativos para mantener un análisis fiable."
        : "Priorizaremos archivos clave para mantener un análisis fiable. Analizaremos primero arquitectura, API, lógica, despliegue y archivos principales del proyecto.";
      return;
    }

    if (preflight.reason === "file_count_limit") {
      showMeasureLimitPanel(preflight);
    }
    measureTitle.textContent = getTooLargeTitle(preflight);
    measureMessage.textContent = getTooLargeMessage(preflight);
  }

  function buildStateMetric(label: string, value: string, accent = false) {
    const item = document.createElement("div");
    item.className = accent ? "doc-state-metric doc-state-metric-accent" : "doc-state-metric";

    const metricLabel = document.createElement("span");
    metricLabel.className = "doc-state-metric-label";
    metricLabel.textContent = label;

    const metricValue = document.createElement("strong");
    metricValue.className = "doc-state-metric-value";
    metricValue.textContent = value;

    item.append(metricLabel, metricValue);
    return item;
  }

  function showPreflightBlocked(preflight: RepoPreflightData) {
    setLeaveProtection(false, true);
    hideDeliveryBanner();

    while (docBody.firstChild) {
      docBody.removeChild(docBody.firstChild);
    }

    const card = document.createElement("section");
    card.className =
      preflight.reason === "file_count_limit"
        ? "doc-state-card doc-state-card-blocked"
        : "doc-state-card";

    const tag = document.createElement("span");
    tag.className = "doc-state-tag";
    tag.textContent =
      preflight.reason === "file_count_limit" ? "Versión gratuita" : "Tamaño del repo";

    const title = document.createElement("h3");
    title.className = "doc-state-title";
    title.textContent =
      preflight.reason === "file_count_limit"
        ? "Este repositorio supera el límite gratuito"
        : "Este repositorio necesita un alcance más pequeño";

    const body = document.createElement("p");
    body.className = "doc-state-body";
    body.textContent = getTooLargeMessage(preflight);

    const metrics = document.createElement("div");
    metrics.className = "doc-state-metrics";

    if (preflight.reason === "file_count_limit") {
      const ratio = (preflight.candidate_files / preflight.candidate_file_limit).toFixed(1);
      metrics.append(
        buildStateMetric("Archivos detectados", String(preflight.candidate_files), true),
        buildStateMetric(
          "Medidos",
          preflight.measurement_limited
            ? `${getMeasuredCandidateCount(preflight)} priorizados`
            : "Todos"
        ),
        buildStateMetric("Plan gratuito", `${preflight.candidate_file_limit} max`),
        buildStateMetric("Relación", `${ratio}x del plan`)
      );
    } else {
      if (preflight.reason === "repo_size_limit") {
        const repoSizeMb = preflight.repo_size_kb
          ? Math.max(1, Math.round(preflight.repo_size_kb / 1024))
          : null;
        const limitMb = preflight.repo_size_limit_mb ?? 100;
        metrics.append(
          buildStateMetric("Tamaño estimado", repoSizeMb ? `~${repoSizeMb} MB` : "No disponible", true),
          buildStateMetric("Límite", `${limitMb} MB`),
          buildStateMetric("Modo", "Una sola pasada")
        );
      } else {
        const measuredCount = getMeasuredCandidateCount(preflight);
        metrics.append(
          buildStateMetric(
            "Archivos clave",
            preflight.measurement_limited
              ? `${preflight.selected_files}/${measuredCount}`
              : `${preflight.selected_files}/${preflight.candidate_files}`
          ),
          buildStateMetric("Chars útiles", formatCompactNumber(preflight.selected_chars)),
          buildStateMetric("Modo", preflight.measurement_limited ? "Priorizado" : "Una sola pasada")
        );
      }
    }

    const note = document.createElement("p");
    note.className = "doc-state-note";
    note.textContent =
      preflight.reason === "file_count_limit"
        ? "No iniciamos el análisis para evitar degradar la calidad y disparar el coste de contexto en la versión gratuita."
        : "Prueba con un repositorio más pequeño o con una versión más acotada del proyecto para obtener un resultado más fiable.";

    const actions = document.createElement("div");
    actions.className = "doc-state-actions";

    const retryLink = document.createElement("a");
    retryLink.className = "doc-state-link";
    retryLink.href = "/";
    retryLink.textContent = "Probar otro repositorio";
    actions.appendChild(retryLink);

    card.append(tag, title, body, metrics, note, actions);
    docBody.appendChild(card);
  }

  async function renderMarkdownInto(
    target: HTMLElement,
    markdown: string,
    wrapperClass = "prose",
  ) {
    const { renderMarkdownInto: renderMarkdown } = await getMarkdownRenderer();
    await renderMarkdown(target, markdown, wrapperClass);
  }

  function syncEmailControls() {
    emailLabel.textContent = "Email para recibir el resultado";
    emailInput.disabled = false;
    emailInput.placeholder = "tu@email.com";
    toggleBtn.disabled = false;
    toggleBtn.classList.remove("toggle-disabled");
    updatesToggleBtn.disabled = false;
    updatesToggleBtn.classList.remove("toggle-disabled");

    if (emailNotificationsEnabled) {
      emailHelp.textContent = "Opcional: te avisamos cuando termine el análisis.";
      toggleSub.textContent = "Tu email solo se usa para enviarte el resultado.";
      updatesSub.textContent =
        "Solo te escribiremos cuando cambie el SHA. Podrás darte de baja desde cualquier correo.";
    } else {
      emailHelp.textContent =
        "Opcional: puedes dejar tu email igualmente mientras terminamos de confirmar el servicio.";
      toggleSub.textContent =
        "Tu email solo se usa para enviarte el resultado cuando el servicio está disponible.";
      updatesSub.textContent =
        "Si activas los avisos futuros, intentaremos avisarte cuando cambie el SHA y haya un análisis nuevo.";
    }

    updateInfoBox();
  }

  // Actualizar la caja informativa en función del email introducido
  function updateInfoBox() {
    if (!emailInput.value.trim() && futureUpdatesOptIn) {
      futureUpdatesOptIn = false;
      updatesToggleBtn.setAttribute("aria-checked", "false");
      updatesToggleBtn.classList.remove("toggle-on");
    }

    toggleSub.textContent = futureUpdatesOptIn
      ? "Usaremos tu email para el resultado y para avisarte de futuros cambios de este repo."
      : "Tu email solo se usa para enviarte el resultado.";
    if (!capabilitiesReady) {
      infoBox.className = "info-box info-amber";
      infoText.textContent =
        "Comprobando si el aviso por email está disponible. El análisis suele tardar entre 3 y 10 minutos.";
      return;
    }

    const hasEmail =
      emailInput.value.trim().length > 0 &&
      privacyAccepted;

    if (hasEmail && futureUpdatesOptIn) {
      infoBox.className = "info-box info-green";
      infoText.textContent =
        "Cuando el análisis haya arrancado podrás cerrar esta pestaña. Te enviaremos el resultado y, si este repo cambia y aparece un análisis nuevo, volveremos a avisarte por email.";
    } else if (hasEmail) {
      infoBox.className = "info-box info-green";
      infoText.textContent =
        "Cuando el análisis haya arrancado podrás cerrar esta pestaña. Suele tardar entre 3 y 10 minutos y te avisaremos por email cuando termine.";
    } else if (!emailNotificationsEnabled) {
      infoBox.className = "info-box info-amber";
      infoText.textContent =
        "Puedes dejar tu email igualmente. En cuanto el análisis arranque, podrás cerrar esta pestaña.";
    } else {
      infoBox.className = "info-box info-amber";
      infoText.textContent =
        "El análisis suele tardar entre 3 y 10 minutos. Cuando arranque podrás cerrar esta pestaña; si añades tu email, te avisaremos al terminar.";
    }
  }

  emailInput.addEventListener("input", updateInfoBox);

  toggleBtn.addEventListener("click", () => {
    privacyAccepted = !privacyAccepted;
    toggleBtn.setAttribute("aria-checked", String(privacyAccepted));
    toggleBtn.classList.toggle("toggle-on", privacyAccepted);
    updateInfoBox();
  });

  updatesToggleBtn.addEventListener("click", () => {
    if (!emailInput.value.trim()) {
      emailInput.focus();
      updatesToggleBtn.classList.add("toggle-shake");
      setTimeout(() => updatesToggleBtn.classList.remove("toggle-shake"), 600);
      return;
    }
    futureUpdatesOptIn = !futureUpdatesOptIn;
    updatesToggleBtn.setAttribute("aria-checked", String(futureUpdatesOptIn));
    updatesToggleBtn.classList.toggle("toggle-on", futureUpdatesOptIn);
    updateInfoBox();
  });

  cancelBtn.addEventListener("click", () => {
    window.location.href = "/";
  });

  popupDialog.addEventListener("keydown", (event) => {
    if (event.key !== "Tab") return;
    const focusable = Array.from(
      popupDialog.querySelectorAll<HTMLElement>(
        "a[href], button:not(:disabled), input:not(:disabled), [tabindex]:not([tabindex='-1'])",
      ),
    );
    if (focusable.length === 0) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (event.shiftKey && document.activeElement === first) {
      event.preventDefault();
      last.focus();
    } else if (!event.shiftKey && document.activeElement === last) {
      event.preventDefault();
      first.focus();
    }
  });

  function setLeaveProtection(active: boolean, safeToLeave: boolean) {
    analysisPendingOrRunning = active;
    canLeaveWithoutRisk = safeToLeave;
  }

  function hideDeliveryBanner() {
    deliveryBanner.className = "delivery-banner delivery-banner-hidden";
    deliveryBannerText.textContent = "";
  }

  function showDeliveryBanner(message: string, tone: "success" | "warning") {
    deliveryBanner.className = `delivery-banner delivery-banner-${tone}`;
    deliveryBannerText.textContent = message;
  }

  window.addEventListener("beforeunload", (event) => {
    if (!analysisPendingOrRunning || canLeaveWithoutRisk) {
      return;
    }

    event.preventDefault();
    event.returnValue = "";
  });

  startBtn.addEventListener("click", async () => {
    if (!capabilitiesReady) {
      return;
    }

    const email = emailInput.value.trim();
    // Validar: si hay email, debe haber aceptado privacidad
    if (email && !privacyAccepted) {
      emailInput.focus();
      toggleBtn.classList.add("toggle-shake");
      setTimeout(() => toggleBtn.classList.remove("toggle-shake"), 600);
      return;
    }

    startBtn.setAttribute("disabled", "true");
    startBtn.textContent = "Midiendo...";
    showMeasuringState();
    infoBox.className = "info-box info-amber";
    infoText.textContent =
      "Midiendo el repositorio antes de iniciar el análisis. Gracias por esperar.";

    collectedEmail =
      privacyAccepted ? email : "";
    const subscribeUpdates = Boolean(collectedEmail) && futureUpdatesOptIn;
    const result = await runAnalysis(
      collectedEmail || undefined,
      forceNewRequested,
      subscribeUpdates,
    );
    if (!result.accepted) {
      setLeaveProtection(false, true);
      if (measureBox.dataset.mode === "too_large") {
        overlay.classList.add("popup-hidden");
      }
      startBtn.removeAttribute("disabled");
      startBtn.textContent = "Iniciar análisis";
      if (measureBox.dataset.mode !== "too_large") {
        updateInfoBox();
      }
      return;
    }

    startBtn.removeAttribute("disabled");
    startBtn.textContent = "Iniciar análisis";
    overlay.classList.add("popup-hidden");
  });

  // ── Helpers de estado de agentes ─────────────────────────────────────────
  type AgentStatus =
    | "pendiente"
    | "en cola"
    | "preparando"
    | "en curso..."
    | "completado"
    | "no disponible";

  type AnalysisStage = "queued" | "preparing" | "analyzing" | "synthesizing";

  const ANALYSIS_AGENT_IDS = [
    "hopper",
    "kay",
    "liskov",
    "fielding",
    "lamarr",
    "knuth",
    "conway",
  ] as const;
  const ALL_AGENT_IDS = [...ANALYSIS_AGENT_IDS, "hamilton"] as const;
  const PROGRESS_STAGE_ORDER: AnalysisStage[] = [
    "queued",
    "preparing",
    "analyzing",
    "synthesizing",
  ];
  const AGENT_BATCH_SIZE = 3;

  function getAgentStatus(agentId: string): string {
    const statusEl = document.getElementById(`status-${agentId}`);
    return statusEl?.textContent?.trim().toLowerCase() ?? "";
  }

  function setAgentStatus(agentId: string, status: AgentStatus) {
    const checkEl  = document.getElementById(`check-${agentId}`)!;
    const statusEl = document.getElementById(`status-${agentId}`)!;
    const rowEl    = document.getElementById(`agent-${agentId}`)!;

    statusEl.textContent = status;
    statusEl.className = "agent-status status-" + status.replace(/\.\.\.$/, "").trim().replace(/ /g, "-");
    rowEl.classList.remove("row-done", "row-warning");
    checkEl.className = "agent-check";

    if (status === "completado") {
      checkEl.textContent = "✓";
      checkEl.className = "agent-check check-done";
      rowEl.classList.add("row-done");
    } else if (status === "en cola") {
      checkEl.textContent = "•";
      checkEl.className = "agent-check check-queued";
    } else if (status === "preparando") {
      checkEl.textContent = "≈";
      checkEl.className = "agent-check check-preparing";
    } else if (status === "en curso...") {
      checkEl.textContent = "·";
      checkEl.className = "agent-check check-running";
    } else if (status === "no disponible") {
      checkEl.textContent = "–";
      checkEl.className = "agent-check check-warning";
      rowEl.classList.add("row-warning");
    } else {
      checkEl.textContent = "\u00a0";
    }
  }

  function resetAgentStatuses() {
    ALL_AGENT_IDS.forEach((id) => setAgentStatus(id, "pendiente"));
  }

  let fullDocument = "";
  const docBody  = document.getElementById("doc-body")!;
  const docTitle = document.getElementById("doc-title")!;
  const docMeta  = document.getElementById("doc-meta")!;
  docMeta.textContent = "Tiempo estimado: entre 3 y 10 minutos, según el tamaño del repositorio.";

  function describePlannedMode(preflight: RepoPreflightData) {
    if (preflight.mode === "optimized") {
      return "Modo previsto: priorización de archivos clave.";
    }
    return "Modo previsto: análisis completo.";
  }

  function buildFallbackPreflight(): RepoPreflightData {
    return {
      mode: "optimized",
      reason: "prioritized_context",
      candidate_files: 0,
      selected_files: 0,
      total_candidate_chars: 0,
      selected_chars: 0,
      oversized_files: 0,
      budget_truncated_files: 0,
      candidate_file_limit: Number(measureLimitCount.textContent || "2500"),
      measured_candidate_files: 0,
      measurement_limited: false,
      repo_size_kb: null,
      repo_size_limit_mb: 100,
    };
  }

  let analysisStage: AnalysisStage | null = null;

  function isTerminalAgentStatus(status: string) {
    return status === "completado" || status === "no disponible";
  }

  function getStageIndex(stage: AnalysisStage) {
    return PROGRESS_STAGE_ORDER.indexOf(stage);
  }

  function getStageLabel(stage: AnalysisStage) {
    switch (stage) {
      case "queued":
        return "Turno reservado";
      case "preparing":
        return "Preparando repositorio";
      case "analyzing":
        return "Agentes en marcha";
      case "synthesizing":
        return "Integrando documento";
    }
  }

  function getStageMeta(preflight: RepoPreflightData, stage: AnalysisStage) {
    const modeLabel =
      preflight.mode === "optimized"
        ? "priorización de archivos clave"
        : "análisis completo";

    switch (stage) {
      case "queued":
        return `modo previsto: ${modeLabel} · esperando hueco`;
      case "preparing":
        return `modo previsto: ${modeLabel} · clonando y leyendo archivos`;
      case "analyzing":
        return `modo previsto: ${modeLabel} · agentes trabajando por tandas`;
      case "synthesizing":
        return `modo previsto: ${modeLabel} · cerrando documento final`;
    }
  }

  function getProgressTitle(stage: AnalysisStage, repoShort: string) {
    switch (stage) {
      case "queued":
        return `${repoShort} ya está aceptado en la cola`;
      case "preparing":
        return `Estamos preparando ${repoShort}`;
      case "analyzing":
        return `Los agentes ya están analizando ${repoShort}`;
      case "synthesizing":
        return `Estamos ensamblando el documento final de ${repoShort}`;
    }
  }

  function getProgressBody(stage: AnalysisStage) {
    switch (stage) {
      case "queued":
        return "El análisis ya está registrado. Si hay otros repos en curso, este paso puede tardar un poco antes de activar a los agentes.";
      case "preparing":
        return "Ahora mismo estamos clonando el repo, leyendo la estructura y priorizando los archivos que nos dan más señal. Por eso todavía no ves contenido final ni a todos los agentes moverse.";
      case "analyzing":
        return "Los especialistas trabajan por tandas para no saturar al proveedor del modelo. Verás cómo se van desbloqueando y entregando secciones según terminen.";
      case "synthesizing":
        return "Las siete especificaciones ya están reunidas. Margaret Hamilton prepara el plano transversal y el sistema conserva intactos sus diagramas, tablas y contratos.";
    }
  }

  function getProgressPulse(stage: AnalysisStage) {
    switch (stage) {
      case "queued":
        return "Reservando hueco en el worker";
      case "preparing":
        return "Clonando, leyendo y priorizando contexto útil";
      case "analyzing":
        return "Despachando especialistas en tandas de tres";
      case "synthesizing":
        return "Creando el plano de reconstrucción y ensamblando la entrega";
    }
  }

  function getProgressDeliveryLabel() {
    if (collectedEmail && futureUpdatesOptIn) {
      return "email + avisos futuros";
    }
    if (collectedEmail) {
      return "email al terminar";
    }
    return "biblioteca";
  }

  function buildProgressStep(label: string, index: number, currentIndex: number) {
    const item = document.createElement("div");
    item.className = "doc-progress-step";

    if (index < currentIndex) {
      item.classList.add("doc-progress-step-done");
    } else if (index === currentIndex) {
      item.classList.add("doc-progress-step-active");
    }

    const badge = document.createElement("span");
    badge.className = "doc-progress-step-badge";
    badge.textContent = index < currentIndex ? "✓" : String(index + 1).padStart(2, "0");

    const text = document.createElement("span");
    text.className = "doc-progress-step-label";
    text.textContent = label;

    item.append(badge, text);
    return item;
  }

  function hasStartedRenderingSections() {
    return Boolean(docBody.querySelector(".doc-section"));
  }

  function showAnalysisProgress(
    stage: AnalysisStage,
    preflight: RepoPreflightData,
    repoShort: string,
  ) {
    analysisStage = stage;
    docMeta.textContent = getStageMeta(preflight, stage);

    if (hasStartedRenderingSections() || hasRenderableDocument(fullDocument)) {
      return;
    }

    while (docBody.firstChild) {
      docBody.removeChild(docBody.firstChild);
    }

    const currentIndex = getStageIndex(stage);
    const card = document.createElement("section");
    card.className = "doc-progress-card";
    card.dataset.stage = stage;

    const tag = document.createElement("span");
    tag.className = "doc-progress-tag";
    tag.textContent = getStageLabel(stage);

    const title = document.createElement("h3");
    title.className = "doc-progress-title";
    title.textContent = getProgressTitle(stage, repoShort);

    const body = document.createElement("p");
    body.className = "doc-progress-body";
    body.textContent = getProgressBody(stage);

    const pulse = document.createElement("div");
    pulse.className = "doc-progress-pulse";

    const pulseTrack = document.createElement("div");
    pulseTrack.className = "doc-progress-track";

    const pulseFill = document.createElement("span");
    pulseFill.className = "doc-progress-fill";
    pulseTrack.appendChild(pulseFill);

    const pulseLabel = document.createElement("span");
    pulseLabel.className = "doc-progress-pulse-label";
    pulseLabel.textContent = getProgressPulse(stage);
    pulse.append(pulseTrack, pulseLabel);

    const steps = document.createElement("div");
    steps.className = "doc-progress-steps";
    PROGRESS_STAGE_ORDER.forEach((item, index) => {
      steps.appendChild(buildProgressStep(getStageLabel(item), index, currentIndex));
    });

    const metrics = document.createElement("div");
    metrics.className = "doc-state-metrics";
    metrics.append(
      buildStateMetric("Modo", preflight.mode === "optimized" ? "Archivos clave" : "Completo", true),
      buildStateMetric("Tiempo", "3-10 min"),
      buildStateMetric("Entrega", getProgressDeliveryLabel()),
    );

    const note = document.createElement("p");
    note.className = "doc-progress-note";
    note.textContent =
      stage === "queued"
        ? "Si hay otros análisis en curso, primero esperaremos turno. En cuanto arranque el worker verás avanzar la preparación."
        : "Puedes dejar esta pantalla abierta o cerrarla si has dejado email. El análisis seguirá hasta biblioteca igualmente.";

    card.append(tag, title, body, pulse, steps, metrics, note);
    docBody.appendChild(card);
  }

  function applyQueuedAgentStatuses() {
    ANALYSIS_AGENT_IDS.forEach((id) => {
      if (!isTerminalAgentStatus(getAgentStatus(id))) {
        setAgentStatus(id, "en cola");
      }
    });
    if (!isTerminalAgentStatus(getAgentStatus("hamilton"))) {
      setAgentStatus("hamilton", "pendiente");
    }
  }

  function applyPreparingAgentStatuses() {
    ANALYSIS_AGENT_IDS.forEach((id) => {
      if (!isTerminalAgentStatus(getAgentStatus(id))) {
        setAgentStatus(id, "preparando");
      }
    });
  }

  function syncAnalyzingAgentStatuses() {
    let runningCount = 0;

    ANALYSIS_AGENT_IDS.forEach((id) => {
      const currentStatus = getAgentStatus(id);
      if (isTerminalAgentStatus(currentStatus)) {
        return;
      }

      if (runningCount < AGENT_BATCH_SIZE) {
        setAgentStatus(id, "en curso...");
        runningCount += 1;
      } else {
        setAgentStatus(id, "en cola");
      }
    });
  }

  function updateAgentStatusesForStage(stage: AnalysisStage) {
    if (stage === "queued") {
      applyQueuedAgentStatuses();
      return;
    }

    if (stage === "preparing") {
      applyPreparingAgentStatuses();
      return;
    }

    if (stage === "analyzing") {
      syncAnalyzingAgentStatuses();
      return;
    }

    if (!isTerminalAgentStatus(getAgentStatus("hamilton"))) {
      setAgentStatus("hamilton", "en curso...");
    }
  }

  function showDocumentWaiting(message: string) {
    analysisStage = null;
    while (docBody.firstChild) {
      docBody.removeChild(docBody.firstChild);
    }

    const waitingP = document.createElement("p");
    waitingP.className = "doc-waiting";
    waitingP.textContent = message;
    docBody.appendChild(waitingP);
  }

  function hasRenderableDocument(doc: string | null | undefined): doc is string {
    return typeof doc === "string" && doc.trim().length > 0;
  }

  async function fetchSavedAnalysisDocument(repoFullName: string): Promise<string | null> {
    const [owner, repo] = repoFullName.split("/", 2);
    if (!owner || !repo) {
      return null;
    }

    const fetchUrl =
      `${ANALYZE_BACKEND_URL}/api/biblioteca/${encodeURIComponent(owner)}/${encodeURIComponent(repo)}`;
    const retryDelays = [0, 300, 800];

    for (const delay of retryDelays) {
      if (delay > 0) {
        await new Promise((resolve) => window.setTimeout(resolve, delay));
      }

      try {
        const response = await fetch(fetchUrl);
        if (!response.ok) {
          continue;
        }

        const entry = (await response.json()) as { document?: string };
        if (hasRenderableDocument(entry.document)) {
          return entry.document;
        }
      } catch {
        // Si la lectura del análisis guardado falla, seguimos con el
        // siguiente intento y luego caeremos al documento del SSE.
      }
    }

    return null;
  }

  async function resolveFinalDocument(
    repoFullName: string,
    streamedDocument: string,
  ): Promise<string | null> {
    const savedDocument = await fetchSavedAnalysisDocument(repoFullName);
    if (hasRenderableDocument(savedDocument)) {
      return savedDocument;
    }

    if (hasRenderableDocument(streamedDocument)) {
      return streamedDocument;
    }

    return null;
  }

  async function runPreflightCheck(): Promise<RepoPreflightData | null> {
    if (!repoUrl) {
      return null;
    }

    hideDeliveryBanner();
    showMeasuringState();
    showDocumentWaiting("Midiendo el repositorio...");

    try {
      const preflight = await measureRepositoryContext(repoUrl);
      showMeasuredState(preflight);

      if (preflight.mode === "too_large") {
        docTitle.textContent = getTooLargeTitle(preflight).replace(/\.$/, "");
        docMeta.textContent =
          preflight.reason === "file_count_limit"
            ? `versión gratuita · límite ${preflight.candidate_file_limit} archivos`
            : preflight.reason === "repo_size_limit"
              ? `límite bruto · ${preflight.repo_size_limit_mb ?? 100} MB`
            : "medición completada";
        infoBox.className = "info-box info-red";
        infoText.textContent =
          preflight.reason === "file_count_limit"
            ? `Este repositorio supera el límite gratuito actual de ${preflight.candidate_file_limit} archivos.`
            : getTooLargeMessage(preflight);
        showPreflightBlocked(preflight);
        return null;
      }

      docMeta.textContent = describePlannedMode(preflight);
      infoBox.className =
        preflight.mode === "optimized" ? "info-box info-amber" : "info-box info-green";
      infoText.textContent =
        preflight.mode === "optimized"
          ? preflight.measurement_limited
            ? "Repositorio amplio detectado. Priorizaremos una selección de archivos clave para mantener un análisis fiable."
            : "Repositorio amplio detectado. Priorizaremos archivos clave para mantener un análisis fiable."
          : "Repositorio apto para análisis completo. Arrancamos el análisis.";

      return preflight;
    } catch (error) {
      const message =
        error instanceof Error && error.message
          ? error.message
          : "No se pudo medir el repositorio.";
      const invalidUrlError =
        /url del repositorio no es válida|repositorio github público válido/i.test(message);

      if (invalidUrlError) {
        infoBox.className = "info-box info-amber";
        infoText.textContent = message;
        showError(message);
        return null;
      }

      hideMeasureLimitPanel();
      measureBox.className = "measure-box measure-optimized";
      measureBox.dataset.mode = "optimized";
      measureTitle.textContent = "No hemos podido medir el repositorio.";
      measureMessage.textContent =
        "Arrancamos el análisis en modo seguro priorizando archivos clave para no bloquearte por una incidencia temporal.";
      measureStats.textContent =
        "Medición temporalmente no disponible · continuamos con arranque directo";
      infoBox.className = "info-box info-amber";
      infoText.textContent = `${message} Arrancamos igualmente en modo seguro.`;
      docMeta.textContent = "medición no disponible · arrancamos en modo seguro";
      showDocumentWaiting("Preparando análisis...");
      return buildFallbackPreflight();
    }
  }

  async function appendSection(agentId: string, section: string) {
    const waiting = docBody.querySelector(".doc-waiting");
    if (waiting) waiting.remove();
    const progressCard = docBody.querySelector(".doc-progress-card");
    if (progressCard) progressCard.remove();

    const block = document.createElement("section");
    block.className = "doc-section";
    block.dataset.agent = agentId;
    docBody.appendChild(block);
    await renderMarkdownInto(block, section, "prose");
    block.scrollIntoView({ behavior: "smooth", block: "end" });
  }

  async function showFinalDocument(doc: string) {
    analysisStage = null;
    await renderMarkdownInto(docBody, doc, "prose doc-final");
  }

  async function finalizeCompletedAnalysis(
    repoFullName: string,
    streamedDocument: string,
    startTime: number,
  ) {
    setLeaveProtection(false, true);
    hideDeliveryBanner();

    const elapsed = ((Date.now() - startTime) / 1000).toFixed(1);
    docMeta.textContent = `análisis: ${elapsed}s · preparando documento final`;

    const finalDocument = await resolveFinalDocument(repoFullName, streamedDocument);
    if (!hasRenderableDocument(finalDocument)) {
      showError(
        "El análisis terminó, pero no pudimos recuperar el documento final. Prueba a abrirlo desde la biblioteca dentro de unos segundos.",
      );
      return;
    }

    ANALYSIS_AGENT_IDS.forEach((id) => {
      const currentStatus = getAgentStatus(id);
      if (currentStatus !== "completado" && currentStatus !== "no disponible") {
        setAgentStatus(id, "no disponible");
      }
    });
    setAgentStatus("hamilton", "completado");

    fullDocument = finalDocument;
    docMeta.textContent = `análisis: ${elapsed}s`;
    await showFinalDocument(finalDocument);
    setupCopyDownload(repoFullName);
  }

  function showError(msg: string) {
    const safeMessage =
      typeof msg === "string" && msg.trim()
        ? msg
        : "Ha ocurrido un error inesperado durante el análisis.";
    setLeaveProtection(false, true);
    analysisStage = null;
    hideDeliveryBanner();
    docTitle.textContent = "Error en el análisis";
    while (docBody.firstChild) docBody.removeChild(docBody.firstChild);
    const p = document.createElement("p");
    p.className = "doc-error";
    p.textContent = safeMessage;
    docBody.appendChild(p);
  }

  // ── Banner de caché ───────────────────────────────────────────────────────
  function showCacheBanner(hasChanges: boolean, repoFullName: string) {
    const banner     = document.getElementById("cache-banner")!;
    const bannerText = document.getElementById("cache-banner-text")!;
    const forceBtn   = document.getElementById("force-new-btn")!;

    banner.classList.remove("cache-banner-hidden");

    if (hasChanges) {
      banner.classList.add("cache-banner-amber");
      bannerText.textContent =
        `El repositorio ${repoFullName} ha cambiado desde el último análisis.`;
      forceBtn.style.display = "inline-block";
    } else {
      banner.classList.add("cache-banner-neutral");
      bannerText.textContent = `Resultado cacheado para ${repoFullName}.`;
      forceBtn.style.display = "none";
    }

    forceBtn.addEventListener("click", () => {
      banner.classList.add("cache-banner-hidden");
      if (repoUrl) {
        void runAnalysis(undefined, true);
      }
    });
  }

  // ── Lógica principal de análisis ──────────────────────────────────────────
  function setupCopyDownload(repoShort: string) {
    const copyBtn = document.getElementById("copy-btn") as HTMLButtonElement;
    const dlBtn   = document.getElementById("download-btn") as HTMLButtonElement;
    copyBtn.disabled = false;
    dlBtn.disabled   = false;

    copyBtn.addEventListener("click", () => {
      navigator.clipboard.writeText(fullDocument).then(() => {
        copyBtn.textContent = "Copiado";
        setTimeout(() => { copyBtn.textContent = "Copiar"; }, 2000);
      });
    });

    dlBtn.addEventListener("click", () => {
      const blob = new Blob([fullDocument], { type: "text/markdown" });
      const a    = document.createElement("a");
      a.href     = URL.createObjectURL(blob);
      a.download = `${repoShort.replace("/", "-")}.md`;
      a.click();
      URL.revokeObjectURL(a.href);
    });
  }

  async function runAnalysis(
    email?: string,
    forceNew = false,
    subscribeUpdates = false,
  ) {
    if (!repoUrl) {
      return { accepted: false, cached: false };
    }

    fullDocument = "";
    analysisStage = null;
    resetAgentStatuses();
    const preflight = await runPreflightCheck();
    if (!preflight) {
      return { accepted: false, cached: false };
    }

    const repoShort = repoUrl.replace("https://github.com/", "");
    docTitle.textContent = `${repoShort} — Documentación de construcción`;
    const ticket = await getAnalysisTicket().catch(() => null);
    if (!ticket) {
      setLeaveProtection(false, true);
      showError("No se pudo preparar el análisis. Recarga la página y vuelve a intentarlo.");
      return { accepted: false, cached: false };
    }

    setLeaveProtection(true, false);
    hideDeliveryBanner();

    const startTime = Date.now();

    // Mostrar "iniciando..." mientras espera respuesta del backend
    showDocumentWaiting("Iniciando análisis...");

    try {
      const result = await startAnalysis(
        repoUrl,
        {
          onStatus(status) {
            if (status === "queued") {
              showAnalysisProgress("queued", preflight, repoShort);
              updateAgentStatusesForStage("queued");
            } else if (status === "cloning") {
              showAnalysisProgress("preparing", preflight, repoShort);
              updateAgentStatusesForStage("preparing");
            } else if (status === "analyzing") {
              showAnalysisProgress("analyzing", preflight, repoShort);
              updateAgentStatusesForStage("analyzing");
            } else if (status === "synthesizing") {
              showAnalysisProgress("synthesizing", preflight, repoShort);
              updateAgentStatusesForStage("synthesizing");
            }
          },

          onAgent({ agent, section }) {
            setAgentStatus(agent, "completado");
            if (analysisStage === "analyzing") {
              syncAnalyzingAgentStatuses();
            }
            void appendSection(agent, section);
          },

          onAgentError({ agent }) {
            setAgentStatus(agent, "no disponible");
            if (analysisStage === "analyzing") {
              syncAnalyzingAgentStatuses();
            }
          },

          onComplete(doc) {
            void finalizeCompletedAnalysis(repoShort, doc, startTime);
          },

          onError: showError,

          onCached(data: CachedAnalysisData) {
            fullDocument = data.document;
            setLeaveProtection(false, true);
            if (email && subscribeUpdates) {
              showDeliveryBanner(
                "Este análisis ya estaba en biblioteca. Te avisaremos si aparece un análisis nuevo de este repo.",
                "success",
              );
            } else {
              hideDeliveryBanner();
            }
            docMeta.textContent = `cacheado el ${new Date(data.updated_at).toLocaleDateString("es-ES")}`;
            void showFinalDocument(data.document).then(() => {
              setupCopyDownload(data.repo_full_name);
            });
            showCacheBanner(data.has_changes, data.repo_full_name);

            // Marcar todos los agentes como completados en el sidebar
            ALL_AGENT_IDS.forEach((id) => setAgentStatus(id, "completado"));
          },
        },
        { forceNew, email, subscribeUpdates, ticket },
      );
      if (!result.accepted) {
        setLeaveProtection(false, true);
        return result;
      }

      if (result.cached) {
        setLeaveProtection(false, true);
        return result;
      }

      showAnalysisProgress("queued", preflight, repoShort);
      updateAgentStatusesForStage("queued");

      if (email && subscribeUpdates) {
        setLeaveProtection(true, true);
        showDeliveryBanner(
          `${describePlannedMode(preflight)} Suele tardar entre 3 y 10 minutos. Puedes cerrar esta pestaña; te enviaremos el resultado a ${email} y te avisaremos también si este repo tiene un análisis nuevo.`,
          "success",
        );
      } else if (email) {
        setLeaveProtection(true, true);
        showDeliveryBanner(
          `${describePlannedMode(preflight)} Suele tardar entre 3 y 10 minutos. Puedes cerrar esta pestaña; te enviaremos el resultado a ${email}.`,
          "success",
        );
      } else {
        setLeaveProtection(true, true);
        showDeliveryBanner(
          `${describePlannedMode(preflight)} Suele tardar entre 3 y 10 minutos. Puedes cerrar esta pestaña; cuando termine estará disponible en biblioteca.`,
          "success",
        );
      }

      return result;
    } catch {
      setLeaveProtection(false, true);
      showError("Error inesperado al conectar con el servidor de análisis");
      return { accepted: false, cached: false };
    }
  }

  // El popup se muestra al cargar la página si hay una URL válida
  if (repoUrl) {
    overlay.classList.remove("popup-hidden");
    window.requestAnimationFrame(() => emailInput.focus());
  }

  startBtn.setAttribute("disabled", "true");
  startBtn.textContent = "Cargando...";
  updateInfoBox();

  void getBackendCapabilities()
    .then((capabilities) => {
      capabilitiesReady = true;
      emailNotificationsEnabled = capabilities.emailNotificationsEnabled;
      syncEmailControls();
      startBtn.removeAttribute("disabled");
      startBtn.textContent = "Iniciar análisis";
    })
    .catch(() => {
      capabilitiesReady = true;
      emailNotificationsEnabled = false;
      syncEmailControls();
      startBtn.removeAttribute("disabled");
      startBtn.textContent = "Iniciar análisis";
    });

</script>

