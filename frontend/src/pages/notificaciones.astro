---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Preferencias de avisos"
  description="Gestiona tus avisos futuros de IWTBI."
  noindex={true}
>
  <section class="notify-shell">
    <div class="notify-card">
      <span class="notify-tag">Avisos futuros</span>
      <h1 id="notify-title" class="notify-title">Confirma la baja</h1>
      <p id="notify-message" class="notify-message">
        Comprueba el ámbito y confirma para dejar de recibir estos avisos.
      </p>

      <div id="notify-track" class="notify-track notify-hidden" aria-hidden="true">
        <span class="notify-fill"></span>
      </div>

      <div id="notify-result" class="notify-result notify-hidden">
        <div class="notify-metric">
          <span class="notify-metric-label">Email</span>
          <strong id="notify-email" class="notify-metric-value">-</strong>
        </div>
        <div class="notify-metric">
          <span class="notify-metric-label">Ámbito</span>
          <strong id="notify-scope" class="notify-metric-value">-</strong>
        </div>
      </div>

      <div class="notify-actions">
        <button id="notify-confirm" class="notify-btn notify-btn-primary" type="button">
          Confirmar baja
        </button>
        <a href="/biblioteca" class="notify-btn notify-btn-primary">Ir a biblioteca</a>
        <a href="/" class="notify-btn notify-btn-secondary">Volver a la home</a>
      </div>

      <p class="notify-note">
        Los análisis que pidas manualmente podrán seguir enviándote un correo si tú lo solicitas al iniciarlos.
      </p>
    </div>
  </section>
</Layout>

<script>
  const BACKEND_URL =
    (import.meta as unknown as { env: Record<string, string> }).env
      ?.PUBLIC_BACKEND_URL ?? "http://localhost:8410";

  const titleEl = document.getElementById("notify-title")!;
  const messageEl = document.getElementById("notify-message")!;
  const resultEl = document.getElementById("notify-result")!;
  const trackEl = document.getElementById("notify-track")!;
  const confirmEl = document.getElementById("notify-confirm") as HTMLButtonElement;
  const emailEl = document.getElementById("notify-email")!;
  const scopeEl = document.getElementById("notify-scope")!;

  const params = new URLSearchParams(window.location.search);
  const action = params.get("action");
  const token = params.get("token");

  if (token) {
    window.history.replaceState({}, "", window.location.pathname);
  }

  const scope =
    action === "unsubscribe-repo"
      ? "repo"
      : action === "unsubscribe-global"
        ? "global"
        : null;

  if (scope === "global") {
    messageEl.textContent = "Dejarás de recibir todos los avisos futuros de IWTBI.";
  } else if (scope === "repo") {
    messageEl.textContent = "Dejarás de recibir avisos futuros de este repositorio.";
  }

  async function run() {
    if (!scope || !token) {
      titleEl.textContent = "Enlace inválido";
      messageEl.textContent =
        "No hemos podido validar este enlace. Pide un correo nuevo desde IWTBI y vuelve a intentarlo.";
      confirmEl.classList.add("notify-hidden");
      return;
    }

    confirmEl.disabled = true;
    trackEl.classList.remove("notify-hidden");
    titleEl.textContent = "Procesando tu preferencia";

    try {
      const response = await fetch(`${BACKEND_URL}/api/subscriptions/unsubscribe`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ scope, token }),
      });

      const data = await response.json().catch(() => ({
        status: "invalid_token",
        message: "No hemos podido procesar este enlace.",
      }));

      titleEl.textContent =
        data.status === "global_unsubscribed"
          ? "Avisos futuros desactivados"
          : data.status === "repo_unsubscribed"
            ? "Repo dado de baja"
            : data.status === "already_inactive"
              ? "No había una suscripción activa"
              : "Enlace inválido";

      messageEl.textContent =
        data.message ??
        "No hemos podido procesar este enlace. Pide un correo nuevo y vuelve a intentarlo.";

      emailEl.textContent = data.email ?? "No disponible";
      scopeEl.textContent =
        scope === "global"
          ? "Todos los avisos futuros"
          : (data.repo_url ?? "Este repositorio").replace("https://github.com/", "");
      resultEl.classList.remove("notify-hidden");
    } catch {
      titleEl.textContent = "No hemos podido completar el cambio";
      messageEl.textContent =
        "Ha fallado la conexión mientras procesábamos tu preferencia. Recarga la página o vuelve a abrir el enlace del correo.";
      confirmEl.disabled = false;
      confirmEl.classList.remove("notify-hidden");
    } finally {
      trackEl.classList.add("notify-hidden");
    }
  }

  if (!scope || !token) {
    confirmEl.classList.add("notify-hidden");
  }
  confirmEl.addEventListener("click", () => {
    confirmEl.classList.add("notify-hidden");
    void run();
  });
</script>

<style>
  .notify-shell {
    min-height: calc(100vh - 180px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px 20px 56px;
    background:
      radial-gradient(circle at top right, rgba(255, 181, 167, 0.28), transparent 32%),
      linear-gradient(180deg, #f6fbff 0%, #eef6ff 100%);
  }

  .notify-card {
    width: min(100%, 760px);
    background: #fff;
    border: 3px solid #000;
    box-shadow: 10px 10px 0 #000;
    padding: 32px;
  }

  .notify-tag {
    display: inline-flex;
    padding: 7px 12px;
    border: 2px solid #000;
    background: #fff173;
    font-family: "Public Sans", sans-serif;
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .notify-title {
    margin: 18px 0 12px;
    font-family: "Archivo Black", sans-serif;
    font-size: clamp(2rem, 4vw, 3.3rem);
    line-height: 0.98;
  }

  .notify-message {
    margin: 0;
    max-width: 58ch;
    font-size: 1.05rem;
    line-height: 1.6;
    color: rgba(0, 0, 0, 0.78);
  }

  .notify-track {
    margin-top: 24px;
    height: 18px;
    border: 2px solid #000;
    background: #fff;
    overflow: hidden;
  }

  .notify-fill {
    display: block;
    width: 42%;
    height: 100%;
    background: linear-gradient(90deg, #ffb5a7 0%, #ff9f8e 100%);
    animation: notify-slide 1.1s ease-in-out infinite;
  }

  .notify-result {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 22px;
  }

  .notify-hidden {
    display: none;
  }

  .notify-metric {
    border: 2px solid #000;
    background: #f8fbff;
    padding: 14px;
  }

  .notify-metric-label {
    display: block;
    font-size: 0.82rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(0, 0, 0, 0.62);
  }

  .notify-metric-value {
    display: block;
    margin-top: 8px;
    font-size: 1rem;
    line-height: 1.45;
  }

  .notify-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 24px;
  }

  .notify-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 20px;
    border: 2px solid #000;
    text-decoration: none;
    font-weight: 800;
    font-size: 1rem;
    box-shadow: 5px 5px 0 #000;
  }

  .notify-btn:disabled {
    cursor: wait;
    opacity: 0.65;
  }

  .notify-btn-primary {
    background: #ffb5a7;
    color: #000;
  }

  .notify-btn-secondary {
    background: #fff;
    color: #000;
  }

  .notify-note {
    margin: 20px 0 0;
    font-size: 0.92rem;
    line-height: 1.55;
    color: rgba(0, 0, 0, 0.62);
  }

  @keyframes notify-slide {
    0%,
    100% {
      transform: translateX(-18%);
    }
    50% {
      transform: translateX(128%);
    }
  }

  @media (max-width: 720px) {
    .notify-card {
      padding: 24px;
      box-shadow: 6px 6px 0 #000;
    }

    .notify-result {
      grid-template-columns: 1fr;
    }

    .notify-actions {
      flex-direction: column;
    }
  }
</style>
