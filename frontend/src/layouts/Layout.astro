---
/**
 * Layout base de IWTBI.
 *
 * Fuentes del diseño:
 * - Archivo Black: títulos display (headings grandes)
 * - Public Sans: UI y cuerpo de texto
 * - Courier New: código y monoespaciado (del sistema)
 *
 * Incluye el modal global de changelog, disponible en todas las páginas
 * a través del botón «Changelog» del footer. Los datos se serializan en
 * tiempo de build desde src/data/changelog.ts.
 */
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  /** Palabras clave adicionales para el meta keywords de la página. */
  keywords?: string;
  /** Ruta absoluta a la imagen Open Graph (relativa a /public). Por defecto /og-image.png. */
  ogImage?: string;
  /** Tipo Open Graph. Por defecto website. */
  ogType?: "website" | "article";
  /** Sección activa del navbar para resaltar el enlace correspondiente. */
  activeLink?: "como-funciona" | "biblioteca";
  /** Texto del botón CTA del navbar. Por defecto «Nuevo análisis». */
  navCtaText?: string;
  /** Destino del botón CTA del navbar. Por defecto «/». */
  navCtaHref?: string;
  /** Control fino del meta robots. */
  robots?: string;
  /** Marca la página como no indexable. */
  noindex?: boolean;
  /** JSON-LD adicional para la página actual. */
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const SITE_URL = (import.meta.env.PUBLIC_APP_URL ?? "http://localhost:3410").replace(/\/+$/, "");
const AUTHOR_URL = import.meta.env.PUBLIC_AUTHOR_URL ?? "";
const SOURCE_URL = import.meta.env.PUBLIC_SOURCE_URL ?? "";
const SOCIAL_HANDLE = import.meta.env.PUBLIC_SOCIAL_HANDLE ?? "";
const LINKEDIN_URL = import.meta.env.PUBLIC_LINKEDIN_URL ?? "";
const SITE_NAME = "IWTBI";
const DEFAULT_DESCRIPTION =
  "Analiza cualquier repositorio público de GitHub y genera documentación exhaustiva lista para reconstruirlo con Claude Code, Gemini CLI o Codex CLI.";
const DEFAULT_KEYWORDS =
  "análisis repositorio GitHub, documentación IA, ingeniería inversa código, Claude Code, Gemini CLI, Codex CLI, Ollama, modelos open source, pipeline agentes IA, reconstruir proyecto";

const {
  title,
  description = DEFAULT_DESCRIPTION,
  keywords = DEFAULT_KEYWORDS,
  ogImage = "/og-image.png",
  ogType = "website",
  activeLink,
  navCtaText = "Nuevo análisis",
  navCtaHref = "/",
  robots,
  noindex = false,
  structuredData,
} = Astro.props;

/** URL canónica: usa la ruta actual dentro del dominio de producción. */
const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).toString();
const ogImageAbsolute = new URL(ogImage, SITE_URL).toString();
const pageTitle = `${title} — ${SITE_NAME}`;
const robotsContent = noindex ? "noindex, follow" : (robots ?? "index, follow");

const structuredDataItems = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: SITE_NAME,
    url: SITE_URL,
    logo: new URL("/og-image.png", SITE_URL).toString(),
    sameAs: [AUTHOR_URL, SOURCE_URL, LINKEDIN_URL].filter(Boolean),
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE_NAME,
    url: SITE_URL,
    inLanguage: "es-ES",
    description,
  },
  ...(structuredData
    ? (Array.isArray(structuredData) ? structuredData : [structuredData])
    : []),
];
const structuredDataJson = JSON.stringify(structuredDataItems);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ── SEO base ── -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={SITE_NAME} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    <meta name="format-detection" content="telephone=no, email=no, address=no" />
    <link rel="alternate" hrefLang="es-ES" href={canonicalUrl} />
    <link rel="alternate" hrefLang="x-default" href={canonicalUrl} />

    <!-- ── Favicon ── -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- ── Open Graph — cubre Facebook, LinkedIn, WhatsApp, Telegram, iMessage… ── -->
    <!-- El protocolo OG es el estándar universal de previsualización en redes sociales. -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:secure_url" content={ogImageAbsolute} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content="Logo de IWTBI — I Want To Build It" />
    <meta property="og:site_name" content="IWTBI — I Want To Build It" />
    <meta property="og:locale" content="es_ES" />

    <!-- ── Twitter / X Card ── -->
    <!-- summary_large_image muestra imagen grande en el tweet; summary muestra miniatura. -->
    <meta name="twitter:card" content="summary_large_image" />
    {SOCIAL_HANDLE && <meta name="twitter:site" content={SOCIAL_HANDLE} />}
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />
    <meta name="twitter:image:alt" content="Logo de IWTBI — I Want To Build It" />

    <!-- ── LinkedIn específico ── -->
    <!-- LinkedIn usa OG estándar; estos refuerzan la autoría y el tipo de contenido. -->
    {LINKEDIN_URL && <meta property="article:author" content={LINKEDIN_URL} />}

    <!-- ── Buscadores ── -->
    <!-- theme-color afecta a la barra de navegación en Chrome para Android. -->
    <meta name="theme-color" content="#000000" />
    <meta name="application-name" content="IWTBI" />

    <script type="application/ld+json" set:html={structuredDataJson}></script>

    <!-- ── Fuentes ── -->
    <link rel="preload" href="/fonts/archivo-black-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/public-sans-latin.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <Navbar activeLink={activeLink} ctaText={navCtaText} ctaHref={navCtaHref} />
    <div style="flex: 1; display: flex; flex-direction: column;">
      <slot />
    </div>
    <Footer />

    <!-- ── Modal changelog (global, disponible en todas las páginas) ── -->
    <div id="cl-overlay" class="cl-overlay cl-hidden" role="dialog" aria-modal="true" aria-label="Changelog">
      <div class="cl-modal">
        <div class="cl-header">
          <span class="cl-title">Changelog</span>
          <button id="cl-close" class="cl-close" aria-label="Cerrar">×</button>
        </div>
        <div class="cl-scroll" id="cl-scroll">
          <!-- Las entradas se renderizan por JavaScript desde window.__CHANGELOG__ -->
        </div>
      </div>
    </div>

    <script>
      let changelogModulePromise;

      function getChangelogModule() {
        changelogModulePromise ??= import("../scripts/changelog-modal");
        return changelogModulePromise;
      }

      async function openChangelog() {
        const changelog = await getChangelogModule();
        changelog.openChangelog();
      }

      async function closeChangelog() {
        const changelog = await getChangelogModule();
        changelog.closeChangelog();
      }

      window.__openChangelog = openChangelog;

      document.addEventListener("DOMContentLoaded", () => {
        document.getElementById("cl-close")?.addEventListener("click", () => {
          void closeChangelog();
        });
        document.getElementById("cl-overlay")?.addEventListener("click", (e) => {
          if (e.target === e.currentTarget) {
            void closeChangelog();
          }
        });
        document.querySelector("[data-action='open-changelog']")
          ?.addEventListener("click", (e) => {
            e.preventDefault();
            void openChangelog();
          });
      });
    </script>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: "Archivo Black";
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url("/fonts/archivo-black-latin.woff2") format("woff2");
  }

  @font-face {
    font-family: "Public Sans";
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url("/fonts/public-sans-latin.woff2") format("woff2");
  }

  @font-face {
    font-family: "Public Sans";
    font-style: normal;
    font-weight: 500;
    font-display: swap;
    src: url("/fonts/public-sans-latin.woff2") format("woff2");
  }

  @font-face {
    font-family: "Public Sans";
    font-style: normal;
    font-weight: 600;
    font-display: swap;
    src: url("/fonts/public-sans-latin.woff2") format("woff2");
  }

  @font-face {
    font-family: "Public Sans";
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url("/fonts/public-sans-latin.woff2") format("woff2");
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg: #ffffff;
    --bg-accent: #e8f4ff;
    --black: #000000;
    --dark: #222222;
    --mid: #444444;
    --muted: #888888;
    --light: #e0e0e0;
    --white: #ffffff;
    --coral: #ffb5a7;
    --green: #c8f5c8;
    --border: 2px solid var(--black);
    --shadow: 4px 4px 0 var(--coral);
    --shadow-dark: 4px 4px 0 var(--black);
    --font-display: "Archivo Black", sans-serif;
    --font-sans: "Public Sans", sans-serif;
    --font-mono: "Courier New", monospace;
    --asset-rev-layout: 202604051500;
  }

  body {
    background: var(--bg);
    font-family: var(--font-sans);
    color: var(--dark);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
  }

  *, *::before, *::after {
    box-sizing: border-box;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  /* Logo de la navbar: icono PNG + texto en coral */
  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }
  .logo-icon {
    width: 28px;
    height: 28px;
    object-fit: contain;
    display: block;
    flex-shrink: 0;
  }
  .logo-text {
    font-family: var(--font-display);
    font-size: 1.1rem;
    letter-spacing: -0.02em;
    color: var(--coral);
  }

  /* Botones de footer con acento coral (Changelog, Privacidad) */
  .btn-footer-accent {
    background: var(--coral) !important;
    box-shadow: var(--shadow-dark) !important;
  }
  .btn-footer-accent:hover {
    background: var(--black) !important;
    color: var(--white) !important;
    box-shadow: 6px 6px 0 var(--black) !important;
  }

  /* Enlace del footer «Creado por» — mantiene el aspecto de texto muted con hover sutil */
  .footer-copy-link {
    color: var(--muted);
    font-size: 0.8rem;
    transition: color 0.1s;
  }
  .footer-copy-link:hover {
    color: var(--dark);
    text-decoration: underline;
  }

  button {
    font-family: var(--font-sans);
    cursor: pointer;
  }

  /* ── Modal changelog ── */
  .cl-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
  }
  .cl-hidden { display: none !important; }

  .cl-modal {
    background: var(--white);
    border: var(--border);
    width: 560px;
    max-width: calc(100vw - 32px);
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    box-shadow: 6px 6px 0 var(--coral);
  }

  .cl-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
    height: 60px;
    border-bottom: var(--border);
    flex-shrink: 0;
  }
  .cl-title { font-family: var(--font-display); font-size: 1.1rem; }
  .cl-close {
    width: 32px;
    height: 32px;
    border: var(--border);
    background: var(--white);
    font-size: 1.1rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.1s;
  }
  .cl-close:hover { background: var(--black); color: var(--white); }

  /* Área con scroll invisible */
  .cl-scroll {
    overflow-y: scroll;
    scrollbar-width: none;
    padding: 20px 24px;
    flex: 1;
  }
  .cl-scroll::-webkit-scrollbar { display: none; }

  /* Bloque de versión */
  .cl-version { padding-bottom: 20px; }
  .cl-sep { border: none; border-top: 1px solid var(--light); margin: 0 0 20px; }

  .cl-version-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }
  .cl-badge {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 3px 10px;
    border: var(--border);
    background: #f0f0f0;
  }
  .cl-badge-latest { background: var(--coral); }
  .cl-date { font-size: 0.75rem; color: var(--muted); }

  /* Etiquetas de categoría */
  .cl-cat {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 2px 8px;
    border: 1px solid;
    margin: 8px 0 6px;
  }
  .cl-cat-added   { background: #e8f5e9; border-color: #81c784; color: #2e7d32; }
  .cl-cat-changed { background: #fff8e1; border-color: #ffd54f; color: #e65100; }
  .cl-cat-fixed   { background: #fce4ec; border-color: #ef9a9a; color: #b71c1c; }

  /* Lista de ítems */
  .cl-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .cl-list li {
    font-size: 0.82rem;
    color: #333;
    line-height: 1.55;
    padding-left: 14px;
    position: relative;
  }
  .cl-list li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--muted);
  }
</style>
