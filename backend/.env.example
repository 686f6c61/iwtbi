# Backend-only development configuration (without Docker Compose).
PROVIDER=openai_compatible
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_MODEL=

NAN_API_KEY=
NAN_BASE_URL=https://api.nan.builders/v1
NAN_MODEL=qwen3.6
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=glm-5.2
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://ollama.com
OLLAMA_CLOUD_MODEL=deepseek-v4-pro:cloud
OLLAMA_CLOUD_FALLBACK_MODELS=kimi-k2.7-code:cloud

DATABASE_BACKEND=postgres
DATABASE_URL=
JOB_STORE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_STORAGE_URI=memory://

PUBLIC_APP_URL=http://localhost:3410
CORS_ORIGINS=http://localhost:3410,http://localhost:4321
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
TRUSTED_PROXY_CIDRS=127.0.0.0/8,::1/128
TRUST_CLOUDFLARE_CLIENT_HEADERS=false
INTERNAL_ANALYZE_TOKEN=

REPO_SIZE_LIMIT_MB=100
FILE_SIZE_LIMIT_KB=500
MAX_FILES=2500
PREFLIGHT_MAX_CANDIDATE_FILES=2500
MAX_CONTEXT_CHARS=90000
ANALYZE_RATE_LIMIT=10/hour
TICKET_RATE_LIMIT=60/minute
PREFLIGHT_RATE_LIMIT=20/minute
BIBLIOTECA_RATE_LIMIT=60/minute
LLM_AGENT_BATCH_SIZE=3
LLM_MAX_CONCURRENCY=3
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_BASE_DELAY_SECONDS=1.5
LLM_REQUEST_TIMEOUT_SECONDS=60
LLM_AGENT_REQUEST_TIMEOUT_SECONDS=60
LLM_AGENT_RETRY_ATTEMPTS=0
LLM_AGENT_MAX_TOKENS=8000
LLM_AGENT_WALL_TIMEOUT_SECONDS=180
LLM_SYNTH_REQUEST_TIMEOUT_SECONDS=60
LLM_SYNTH_RETRY_ATTEMPTS=0
LLM_SYNTH_RETRY_BASE_DELAY_SECONDS=4
API_DOCS_ENABLED=true

RESEND_API_KEY=
RESEND_FROM=
EMAIL_UNSUBSCRIBE_SECRET=
EMAIL_UNSUBSCRIBE_TOKEN_TTL_DAYS=180
