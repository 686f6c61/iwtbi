# Root environment for local Docker Compose.
# Copy this file to `.env` and fill in the real values for your setup.

# ---------------------------------------------------------------------------
# Model provider
# ---------------------------------------------------------------------------
PROVIDER=zai

# z.ai (OpenAI-compatible)
ZAI_API_KEY=your_z_ai_key_here
ZAI_BASE_URL=https://api.z.ai/v1
ZAI_MODEL=glm-z1-flash

# Ollama Cloud
# IMPORTANT: OLLAMA_CLOUD_BASE_URL must not end with /api.
OLLAMA_CLOUD_API_KEY=your_ollama_cloud_key_here
OLLAMA_CLOUD_BASE_URL=https://ollama.com
OLLAMA_CLOUD_MODEL=qwen3.5

# ---------------------------------------------------------------------------
# API and runtime limits
# ---------------------------------------------------------------------------
REPO_SIZE_LIMIT_MB=100
FILE_SIZE_LIMIT_KB=500
MAX_FILES=2000
PREFLIGHT_MAX_CANDIDATE_FILES=750
MAX_CONTEXT_CHARS=80000

ANALYZE_RATE_LIMIT=5/hour
TICKET_RATE_LIMIT=30/minute
PREFLIGHT_RATE_LIMIT=12/minute

LLM_MAX_CONCURRENCY=4
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_BASE_DELAY_SECONDS=1.5
LLM_REQUEST_TIMEOUT_SECONDS=60
LLM_SYNTH_REQUEST_TIMEOUT_SECONDS=120
LLM_SYNTH_RETRY_ATTEMPTS=2
LLM_SYNTH_RETRY_BASE_DELAY_SECONDS=4

# ---------------------------------------------------------------------------
# App URLs and local ports
# ---------------------------------------------------------------------------
PUBLIC_BACKEND_URL=http://localhost:8410
CORS_ORIGINS=http://localhost:3410,http://localhost:4321
IWTBI_FRONTEND_PORT=3410
IWTBI_BACKEND_PORT=8410

# ---------------------------------------------------------------------------
# Persistence (required for cache + library)
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ---------------------------------------------------------------------------
# Email notifications (optional)
# ---------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM=hola@example.com
